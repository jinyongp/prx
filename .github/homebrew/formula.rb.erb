class <%= class_name %> < Formula
  desc "Local-dev global HTTPS reverse proxy and port registry"
  homepage <%= "https://github.com/#{repository}".dump %>
  url <%= archive_url.dump %>
  sha256 <%= sha256.dump %>
  version <%= version.delete_prefix("v").dump %>
  license "MIT"

  depends_on "go" => :build

  def install
    system "go", "build", *std_go_args(
      ldflags: "-s -w -X main.version=v#{version}",
      output: bin/"gate",
    ), "./cmd/gate"
  end

  test do
    assert_match "v#{version}", shell_output("#{bin}/gate --version")
  end
end
